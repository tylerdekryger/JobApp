DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/job_intelligence
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/job_intelligence_test
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
# Fit/gap analysis (Gemini preferred, free tier, no card):
GEMINI_API_KEY=
# Auto-discover web search (Tavily free tier: 1,000/month, no card):
TAVILY_API_KEY=
# Optional fallback — used if Gemini/Tavily aren't set:
ANTHROPIC_API_KEY=

# Daily email digest (Gmail SMTP). Generate an App Password at
# https://myaccount.google.com/apppasswords (turn on 2FA first).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_TO_EMAIL=
# Local hour of day (America/New_York) for the Mon-Fri digest email:
DIGEST_HOUR_ET=8
